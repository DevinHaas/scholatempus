{
  "extends": "../../tsconfig.base.json",
  "name": "scholatempus-backend",
  "private": true,
  "version": "0.0.1",
  "description": "The official backend for scholatempus",
  "license": "MPL-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@types/node": "^20.19.27",
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.20.6",
    "typescript": "^5.2.2",
    "@scholatempus/typescript-config": "workspace:*"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.51.0",
    "@elysiajs/cors": "latest",
    "@elysiajs/openapi": "latest",
    "@scholatempus/shared": "workspace:*",
    "@sinclair/typebox": "^0.34.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "drizzle-typebox": "latest",
    "elysia": "latest",
    "elysia-clerk": "latest",
    "pg": "^8.16.3"
  }
}

