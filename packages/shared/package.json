{
  "name": "@scholatempus/shared",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "build": "tsc",
    "dev": "tsc",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
