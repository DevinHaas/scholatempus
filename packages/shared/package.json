{
  "name": "@scholatempus/shared",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "build": "tsc",
    "dev": "tsc",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./api-types": {
      "types": "./src/api-types.ts",
      "default": "./dist/api-types.js"
    },
    "./enums": {
      "types": "./src/enums.ts",
      "default": "./dist/enums.js"
    },
    "./schemas": {
      "types": "./src/schemas.ts",
      "default": "./dist/schemas.js"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./dist/types.js"
    }
  },
  "dependencies": {
    "zod": "^3.25.67"
  }
}
